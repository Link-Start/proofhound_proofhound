{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": false,
    "paths": {
      "@proofhound/shared": ["./packages/shared/src/index.ts"],
      "@proofhound/shared/*": ["./packages/shared/src/*"],
      "@proofhound/db": ["./packages/db/src/index.ts"],
      "@proofhound/db/*": ["./packages/db/src/*"],
      "@proofhound/orchestration-shared": ["./packages/orchestration-shared/src/index.ts"],
      "@proofhound/orchestration-shared/*": ["./packages/orchestration-shared/src/*"],
      "@proofhound/api-client": ["./packages/api-client/src/index.ts"],
      "@proofhound/api-client/*": ["./packages/api-client/src/*"],
      "@proofhound/logger": ["./packages/logger/src/index.ts"],
      "@proofhound/logger/*": ["./packages/logger/src/*"],
      "@proofhound/limiter": ["./packages/limiter/src/index.ts"],
      "@proofhound/limiter/*": ["./packages/limiter/src/*"],
      "@proofhound/llm-client": ["./packages/llm-client/src/index.ts"],
      "@proofhound/llm-client/*": ["./packages/llm-client/src/*"],
      "@proofhound/connector-client": ["./packages/connector-client/src/index.ts"],
      "@proofhound/connector-client/*": ["./packages/connector-client/src/*"],
      "@proofhound/crypto": ["./packages/crypto/src/index.ts"],
      "@proofhound/crypto/*": ["./packages/crypto/src/*"],
      "@proofhound/judgment": ["./packages/judgment/src/index.ts"],
      "@proofhound/judgment/*": ["./packages/judgment/src/*"],
      "@proofhound/metrics": ["./packages/metrics/src/index.ts"],
      "@proofhound/metrics/*": ["./packages/metrics/src/*"],
      "@proofhound/optimization-strategy": ["./packages/optimization-strategy/src/index.ts"],
      "@proofhound/optimization-strategy/*": ["./packages/optimization-strategy/src/*"],
      "@proofhound/ui": ["./packages/ui/src/index.ts"],
      "@proofhound/ui/*": ["./packages/ui/src/*"],
      "@proofhound/web-ui": ["./packages/web-ui/src/index.ts"],
      "@proofhound/web-ui/screens": ["./packages/web-ui/src/screens/index.ts"],
      "@proofhound/web-ui/hooks": ["./packages/web-ui/src/hooks/index.ts"],
      "@proofhound/web-ui/providers": ["./packages/web-ui/src/providers/index.ts"],
      "@proofhound/web-ui/i18n": ["./packages/web-ui/src/i18n/index.tsx"],
      "@proofhound/web-ui/i18n/language": ["./packages/web-ui/src/i18n/language.ts"],
      "@proofhound/web-ui/components": ["./packages/web-ui/src/components/index.ts"],
      "@proofhound/web-ui/lib": ["./packages/web-ui/src/lib/index.ts"],
      "@proofhound/web-ui/contracts": ["./packages/web-ui/src/contracts/index.ts"],
      "@proofhound/core": ["./packages/core/src/index.ts"],
      "@proofhound/core/server": ["./packages/core/src/server/index.ts"],
      "@proofhound/core/webhook": ["./packages/core/src/webhook/index.ts"],
      "@proofhound/core/worker": ["./packages/core/src/worker/index.ts"],
      "@proofhound/core/worker/config": ["./packages/core/src/worker/config/worker-concurrency.ts"],
      "@proofhound/core/contracts": ["./packages/core/src/server/common/contracts/index.ts"],
      "@proofhound/core/infra": ["./packages/core/src/infra/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo", "coverage"]
}
