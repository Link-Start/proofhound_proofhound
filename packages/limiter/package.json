{
  "name": "@proofhound/limiter",
  "version": "0.1.17",
  "description": "Redis centralized rate limiting (RPM / TPM sliding window + atomic Lua scripts) — RPM / TPM / concurrency",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --dir src --exclude \"**/*.integration.test.ts\"",
    "test:unit": "vitest run --dir src --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run --dir src integration.test",
    "demo:auto-concurrency": "tsx examples/auto-concurrency-trajectory.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/logger": "workspace:*",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/limiter"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/limiter#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
