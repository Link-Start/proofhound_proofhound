{
  "name": "@proofhound/optimization-strategy",
  "version": "0.1.7",
  "description": "Optimization strategies (extension point) — V1: error_pattern_analysis; new strategies can be registered without DB CHECK changes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-prompt-assets.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:unit": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "example:real-llm": "tsx examples/run-real-llm.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/judgment": "workspace:*",
    "@proofhound/limiter": "workspace:*",
    "@proofhound/llm-client": "workspace:*",
    "@proofhound/logger": "workspace:*",
    "@proofhound/metrics": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "jsonrepair": "^3.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/optimization-strategy"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/optimization-strategy#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
