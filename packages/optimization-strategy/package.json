{
  "name": "@proofhound/optimization-strategy",
  "version": "0.0.0",
  "private": true,
  "description": "优化策略（扩展点）— V1: error_pattern_analysis；可注册新策略，无需 DB CHECK 改动",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-prompt-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:unit": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "example:real-llm": "tsx examples/run-real-llm.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/judgment": "workspace:*",
    "@proofhound/limiter": "workspace:*",
    "@proofhound/llm-client": "workspace:*",
    "@proofhound/logger": "workspace:*",
    "@proofhound/metrics": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "jsonrepair": "^3.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
