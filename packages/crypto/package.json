{
  "name": "@proofhound/crypto",
  "version": "0.1.17",
  "description": "Shared symmetric encryption util — AES-256-GCM encryption/decryption of API keys / credential ciphertexts, the single source of truth for server / worker / seed",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/crypto"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/crypto#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
