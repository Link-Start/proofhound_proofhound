{
  "name": "@proofhound/web-ui",
  "version": "0.1.17",
  "description": "ProofHound reusable product frontend: screens / hooks / providers / i18n / components / contracts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./screens": "./dist/screens/index.js",
    "./hooks": "./dist/hooks/index.js",
    "./providers": "./dist/providers/index.js",
    "./i18n": "./dist/i18n/index.js",
    "./i18n/language": "./dist/i18n/language.js",
    "./components": "./dist/components/index.js",
    "./lib": "./dist/lib/index.js",
    "./contracts": "./dist/contracts/index.js",
    "./styles/globals.css": "./dist/styles/globals.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@proofhound/api-client": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "@proofhound/ui": "workspace:*",
    "@refinedev/core": "^5.0.12",
    "@refinedev/nextjs-router": "^7.0.5",
    "@tanstack/react-query": "^5.100.10",
    "@uiw/react-codemirror": "^4.25.9",
    "@uppy/core": "^5.2.0",
    "@uppy/react": "^5.2.0",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "jsonc-parser": "3.3.1",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.4",
    "recharts": "^3.3.1"
  },
  "peerDependencies": {
    "next": "^16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/web-ui"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/web-ui#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles/globals.css"
  ]
}
