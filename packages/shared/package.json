{
  "name": "@proofhound/shared",
  "version": "0.1.20",
  "description": "Zod schemas / DTOs / enums / types shared between frontend and backend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./dto/*": "./dist/dto/*.js",
    "./enums/*": "./dist/enums/*.js",
    "./types/*": "./dist/types/*.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/shared#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
