{
  "name": "@proofhound/shared",
  "version": "0.0.0",
  "private": true,
  "description": "前后端共享的 Zod schema / DTO / 枚举 / 类型",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dto/*": "./src/dto/*.ts",
    "./enums/*": "./src/enums/*.ts",
    "./types/*": "./src/types/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
