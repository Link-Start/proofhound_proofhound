{
  "name": "@proofhound/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle ORM schema + migrations（schema 前缀 ph_*）",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "ensure:e2e": "tsx src/ensure-e2e-database.ts",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "reset": "tsx src/reset.ts && pnpm migrate && pnpm seed",
    "seed": "tsx src/seed.ts",
    "seed:dev": "SEED_PROFILE=dev tsx src/seed-dev.ts",
    "clean-test-residue": "tsx src/clean-test-residue.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/crypto": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
