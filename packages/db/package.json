{
  "name": "@proofhound/db",
  "version": "0.1.8",
  "description": "Drizzle ORM schema + migrations (schema prefix ph_*)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./schema/*": "./dist/schema/*"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "ensure:e2e": "tsx src/ensure-e2e-database.ts",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "reset": "tsx src/reset.ts && pnpm migrate && pnpm seed",
    "seed": "tsx src/seed.ts",
    "seed:dev": "SEED_PROFILE=dev tsx src/seed-dev.ts",
    "clean-test-residue": "tsx src/clean-test-residue.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/crypto": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/db"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/db#readme",
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
