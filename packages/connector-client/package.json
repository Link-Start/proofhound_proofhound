{
  "name": "@proofhound/connector-client",
  "version": "0.0.0",
  "private": true,
  "description": "连接器驱动 — Redis List / Stream / Kafka / Webhook（输入 + 输出 + 探测）",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "dev:kafka:mock": "node scripts/stream-mock-to-kafka.mjs",
    "dev:redis:mock": "node scripts/stream-mock-to-redis.mjs",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/logger": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
