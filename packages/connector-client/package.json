{
  "name": "@proofhound/connector-client",
  "version": "0.1.22",
  "description": "Connector drivers — Redis List / Stream / Kafka / Webhook (input + output + probing)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "dev:kafka:mock": "node scripts/stream-mock-to-kafka.mjs",
    "dev:redis:mock": "node scripts/stream-mock-to-redis.mjs",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@proofhound/logger": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofhound/proofhound",
    "directory": "packages/connector-client"
  },
  "homepage": "https://github.com/proofhound/proofhound/tree/master/packages/connector-client#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
