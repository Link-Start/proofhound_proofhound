{
  "name": "proofhound",
  "version": "0.1.5",
  "private": true,
  "license": "Apache-2.0",
  "description": "ProofHound — Prompt 全生命周期治理平台",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "pnpm dev:docker:ready && pnpm db:migrate && concurrently -p \"[{time}] [{name}]\" --timestamp-format \"yyyy-MM-dd HH:mm:ss.SSS\" -n docker,server,webhook,worker,web -c gray,blue,cyan,green,magenta \"pnpm dev:docker:logs\" \"pnpm dev:server\" \"pnpm dev:webhook\" \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @proofhound/server dev",
    "dev:webhook": "pnpm --filter @proofhound/webhook dev",
    "dev:worker": "pnpm --filter @proofhound/worker dev",
    "dev:web": "pnpm --filter @proofhound/web dev",
    "dev:docker": "docker compose -f dev/docker-compose.yml up postgres redis kafka redpanda-console redis-insight",
    "dev:docker:ready": "docker compose -f dev/docker-compose.yml up -d --wait --wait-timeout 180 postgres redis kafka redpanda-console redis-insight",
    "dev:docker:logs": "docker compose -f dev/docker-compose.yml logs --tail=100 -f postgres redis kafka redpanda-console redis-insight",
    "dev:kafka:mock": "pnpm --filter @proofhound/connector-client dev:kafka:mock",
    "dev:redis:mock": "pnpm --filter @proofhound/connector-client dev:redis:mock",
    "dev:reset": "pnpm db:reset",
    "test:webhook:canary": "node scripts/test-webhook-canary.mjs",
    "build": "turbo run build --filter='@proofhound/*'",
    "build:server": "turbo run build --filter @proofhound/server",
    "build:webhook": "turbo run build --filter @proofhound/webhook",
    "build:worker": "turbo run build --filter @proofhound/worker",
    "build:web": "turbo run build --filter @proofhound/web",
    "typecheck": "turbo run typecheck --filter='@proofhound/*'",
    "lint": "turbo run lint --filter='@proofhound/*'",
    "lint:fix": "turbo run lint --filter='@proofhound/*' -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "test": "turbo run test --filter='@proofhound/*'",
    "test:unit": "turbo run test:unit --filter='@proofhound/*'",
    "test:e2e": "pnpm --filter @proofhound/web test:e2e",
    "test:e2e:ui": "pnpm --filter @proofhound/web test:e2e:ui",
    "test:watch": "turbo run test --filter='@proofhound/*' -- --watch",
    "test:coverage": "turbo run test --filter='@proofhound/*' -- --coverage",
    "db:generate": "pnpm --filter @proofhound/db generate",
    "db:migrate": "pnpm --filter @proofhound/db migrate",
    "db:migrate:prod": "dotenv -e .env.production -- pnpm --filter @proofhound/db migrate",
    "db:studio": "pnpm --filter @proofhound/db studio",
    "db:reset": "pnpm --filter @proofhound/db reset",
    "db:seed": "pnpm --filter @proofhound/db seed",
    "db:seed:dev": "pnpm --filter @proofhound/db seed:dev",
    "db:clean-test-residue": "pnpm --filter @proofhound/db clean-test-residue",
    "probe:model": "pnpm --filter @proofhound/worker probe:model",
    "docker:build": "pnpm docker:build:server && pnpm docker:build:webhook && pnpm docker:build:worker && pnpm docker:build:web",
    "docker:build:server": "docker build -f apps/server/Dockerfile -t proofhound-server:local .",
    "docker:build:webhook": "docker build -f apps/webhook/Dockerfile -t proofhound-webhook:local .",
    "docker:build:worker": "docker build -f apps/worker/Dockerfile -t proofhound-worker:local .",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t proofhound-web:local .",
    "docker:up": "docker compose -f dev/docker-compose.yml up -d",
    "docker:down": "docker compose -f dev/docker-compose.yml down",
    "docker:logs": "docker compose -f dev/docker-compose.yml logs -f",
    "deps:check": "madge --circular --extensions ts,tsx --exclude '(^|/)dist/' packages/ apps/",
    "deps:graph": "madge --image deps.svg --extensions ts,tsx packages/ apps/",
    "deps:orphans": "madge --orphans --extensions ts,tsx packages/ apps/",
    "spec:terms": "node scripts/check-stale-terms.mjs",
    "clean": "turbo run clean --filter='@proofhound/*' && rm -rf node_modules .turbo",
    "clean:soft": "turbo run clean --filter='@proofhound/*'",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm deps:check && pnpm spec:terms"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msgpackr-extract",
      "sharp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3"
  }
}
