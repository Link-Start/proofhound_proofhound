{
  "name": "@proofhound/server",
  "version": "0.0.0",
  "private": true,
  "description": "ProofHound NestJS Server — REST / MCP management API + DBOS workflow runtime + BullMQ producer / self-consumer",
  "main": "dist/main.js",
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=1000 nest start --watch --webpack 2>&1 | tee /tmp/proofhound-server.log | pino-pretty --colorize --translateTime \"SYS:yyyy-mm-dd HH:MM:ss.l\" --ignore \"pid,hostname,service,version,env,host,namespace\"",
    "build": "nest build --webpack",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "start": "node dist/main.js",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.18.10",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@proofhound/core": "workspace:*",
    "@proofhound/optimization-strategy": "workspace:*",
    "@proofhound/connector-client": "workspace:*",
    "@proofhound/crypto": "workspace:*",
    "@proofhound/db": "workspace:*",
    "@proofhound/judgment": "workspace:*",
    "@proofhound/limiter": "workspace:*",
    "@proofhound/llm-client": "workspace:*",
    "@proofhound/logger": "workspace:*",
    "@proofhound/metrics": "workspace:*",
    "@proofhound/orchestration-shared": "workspace:*",
    "@proofhound/shared": "workspace:*",
    "bullmq": "^5.76.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jsonrepair": "^3.14.0",
    "kafkajs": "^2.2.4",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@swc/core": "^1.13.20",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.4",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.6"
  }
}
