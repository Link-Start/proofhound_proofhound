# ProofHound 环境变量模板
#
# 根目录 `.env` 由 apps/server、apps/webhook、apps/worker 与 packages/db 脚本读取。
# apps/web 是 Next.js 应用；本地开发时通常从 `apps/web/.env.local` 读取 NEXT_PUBLIC_*。

# ============ Shared · runtime ============
NODE_ENV=development
LOG_LEVEL=debug

# 可选部署元数据：logger / seed 安全检查会读取。
# APP_ENV=development
# SERVICE_NAME=
# APP_VERSION=
# GIT_SHA=

# ============ Shared · database / queue ============
# 本地 docker compose 默认：postgresql://postgres:postgres@127.0.0.1:5432/proofhound
DATABASE_URL=postgres://postgres:postgres@localhost:5432/proofhound
REDIS_URL=redis://localhost:6379

# ============ Shared · model secret encryption ============
# server / worker / dev seed 用它加密静态存储的模型 API key。
# 本地真实密钥生成命令：openssl rand -base64 32
MODEL_API_KEY_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# ============ apps/server ============
SERVER_PORT=4000
SERVER_PUBLIC_URL=http://localhost:4000
SERVER_BODY_LIMIT=10mb

# apps/web 的 CORS origin；未设置时 server 本地兜底为 http://localhost:3000。
WEB_PUBLIC_URL=http://localhost:3000

MCP_TOKEN_SIGNING_SECRET=local-dev-mcp-token-secret-change-me

# 可选灰度 runner 轮询间隔覆盖。
CANARY_RUNNER_SCAN_INTERVAL_MS=5000

# ============ apps/webhook ============
WEBHOOK_BODY_LIMIT=1mb

# ============ apps/worker ============
WORKER_QUEUES=llm,probe
WORKER_CONCURRENCY=64

# ============ apps/web ============
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# ============ packages/db · seed / reset ============
# 只有确认要重置非本地数据库时才设为 1。
# ALLOW_DB_RESET=0

# dev seed 脚本会通过 SEED_PROFILE=dev 显式开启。
# SEED_PROFILE=dev
# ALLOW_DEV_SEED=false
# SEED_LOCALE=zh-CN
# DEV_SEED_LOCALE=zh-CN

# dev seed fixture 可选 provider key。
# MODEL_QIANFAN_PROBE_API_KEY=

# ============ Tests ============
# TEST_DATABASE_URL 用于开启 DBOS 集成测试；未设置则跳过。
# TEST_DATABASE_URL=
# REDIS_TEST_URL=redis://localhost:6379
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ============ Local scripts · model probe ============
# 使用方：pnpm probe:model
MODEL_PROBE_PROVIDER_TYPE=openai
MODEL_PROBE_MODEL_ID=gpt-4o-mini
MODEL_PROBE_ENDPOINT=https://api.openai.com
MODEL_PROBE_API_KEY=
MODEL_PROBE_TIMEOUT_MS=30000
MODEL_PROBE_IMAGE_CAPABILITY=none
MODEL_PROBE_RPM_LIMIT=60
MODEL_PROBE_TPM_LIMIT=100000
MODEL_PROBE_CONCURRENCY_LIMIT=1
MODEL_PROBE_INPUT_PRICE_PER_MILLION=0
MODEL_PROBE_OUTPUT_PRICE_PER_MILLION=0

# ============ Local scripts · real LLM examples ============
# RUN_REAL_LLM=1
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ============ Local scripts · webhook canary ============
# 使用方：pnpm test:webhook:canary
# PROOFHOUND_WEBHOOK_URL=
# PROOFHOUND_WEBHOOK_SYNC_URL=
# PROOFHOUND_WEBHOOK_ASYNC_URL=
# PROOFHOUND_WEBHOOK_ASYNC_QUERY_URL=
# PROOFHOUND_WEBHOOK_TOKEN=
# PROJECT_API_TOKEN=

# ============ Local scripts · connector demos ============
# DATASET_PATH=
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=proofhound-samples
# REDIS_QUEUE_KEY=proofhound:samples
# REDIS_PUSH_SIDE=right
